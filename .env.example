# Public-safe environment template.
# Do not put real API keys, secrets, tokens, account IDs, or exchange account data here.

TRADING_MODE=paper
LIVE_TRADING_ENABLED=false

# Live trading must remain disabled unless docs/LIVE_TRADING_GATE.md is satisfied.
LIVE_TRADING_ACKNOWLEDGED=false

# Credentials must be supplied only through local, uncommitted secrets.
# Exchange API keys must have withdrawal permission disabled.
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_ACCOUNT_ID=
